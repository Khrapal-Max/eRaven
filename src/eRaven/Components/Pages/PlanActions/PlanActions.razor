@page "/plan-actions"

@using eRaven.Components.Pages.PlanActions.Modals
@using eRaven.Domain.Enums
@using eRaven.Domain.Models
@using eRaven.Application.Services.PlanActionService
@using eRaven.Components.Shared.TableBaseComponent

<PageTitle>Планові дії</PageTitle>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-8">
                <label class="form-label">Пошук (ПІБ або ІПН)</label>
                <input class="form-control"
                       @bind="SearchText"
                       @bind:event="oninput"
                       placeholder="Напр.: Іваненко Іван або 1234567890" />
            </div>
            <div class="col-md-4 d-grid">
                <button class="btn btn-primary" @onclick="SearchAsync">Пошук</button>
            </div>
        </div>

        <div class="row g-2 mt-2">
            <div class="col-md-6">
                <small class="text-muted">Показуються перші 100 результатів за датою (нові зверху).</small>
            </div>
            <div class="col-md-6 text-end">
                <button class="btn btn-success me-2" @onclick="OpenCreateModal">Додати</button>
                <button class="btn btn-outline-primary me-2" @onclick="ApproveSelected" disabled="@(SelectedIds.Count == 0)">Затвердити наказом</button>
                <button class="btn btn-outline-danger" @onclick="DeleteSelected" disabled="@(SelectedIds.Count == 0)">Видалити</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <TableBaseComponent TItem="PlanAction"
                            Items="Items"
                            SelectedItem="Selected"
                            SelectedItemChanged="OnSelectedChanged"
                            OnClick="ToggleSelect"
                            MaxHeight="70vh"
                            Class="align-middle">
            <TableHeader>
                <th class="text-black" scope="col">#</th>
                <th class="text-black" scope="col">Особа</th>
                <th class="text-black" scope="col">Тип</th>
                <th class="text-black" scope="col">Дата/час (UTC)</th>
                <th class="text-black" scope="col">Trip</th>
                <th class="text-black" scope="col">Статус →</th>
                <th class="text-black" scope="col">Стан</th>
                <th class="text-black" scope="col">Наказ</th>
                <th class="text-black" scope="col">Локація</th>
                <th class="text-black text-end" scope="col">Дії</th>
            </TableHeader>
            <RowTemplate Context="a">
                <td>
                    <input type="checkbox" class="form-check-input" checked="@SelectedIds.Contains(a.Id)" />
                </td>
                <td class="text-truncate" style="max-width:240px">@a.FullName (@a.Callsign)</td>
                <td>@a.MoveType</td>
                <td>@a.EffectiveAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                <td class="text-truncate" style="max-width:140px">@a.TripId</td>
                <td>@a.ToStatusKindId</td>
                <td>@a.ActionState</td>
                <td>@a.Order</td>
                <td class="text-truncate" style="max-width:140px">@a.Location</td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-secondary me-1"
                            @onclick="() => OpenEditModal(a)"
                            disabled="@(a.ActionState != ActionState.PlanAction)">
                        Ред.
                    </button>
                    <button class="btn btn-sm btn-outline-danger"
                            @onclick="() => DeleteOne(a.Id)"
                            disabled="@(a.ActionState != ActionState.PlanAction)">
                        ×
                    </button>
                </td>
            </RowTemplate>
        </TableBaseComponent>

        <div class="d-flex justify-content-between mt-2">
            <div class="small text-muted">Всього знайдено: @Total</div>
            <div class="small text-muted">Вибрано: @SelectedIds.Count</div>
        </div>
    </div>
</div>

@* Модали *@
@if (ShowCreate)
{
    <PlanActionModal Title="Додати дію"
                     PersonId="PreselectedPersonId"
                     OnSaved="OnModalSaved"
                     OnCancel="CloseCreateModal" />
}
@if (ShowEdit && EditTarget is not null)
{
    <PlanActionModal Title="Редагувати дію"
                     ActionId="EditTarget.Id"
                     OnSaved="OnModalSaved"
                     OnCancel="CloseEditModal" />
}
@if (ShowApprove)
{
    <ApproveOrderModal SelectedIds="SelectedIds"
                       OnApproved="OnApproved"
                       OnCancel="CloseApproveModal" />
}
