@using eRaven.Application.Services.PlanActionService

<div class="modal-backdrop fade show"></div>
<div class="modal d-block" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Затвердити наказом</h5>
                <button type="button" class="btn-close" @onclick="OnCancel"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@Vm" OnValidSubmit="@ApproveAsync">
                    <FluentValidationValidator />
                    <div class="mb-2">
                        <label class="form-label">Наказ</label>
                        <input class="form-control" @bind="Vm.OrderName" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Автор</label>
                        <input class="form-control" @bind="Vm.Author" />
                    </div>
                    <div class="alert alert-info">
                        Обрано дій: @SelectedIds.Count
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-success" type="submit">Затвердити</button>
                        <button class="btn btn-secondary" type="button" @onclick="OnCancel">Скасувати</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>
