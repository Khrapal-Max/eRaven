@using eRaven.Domain.Enums
@using eRaven.Application.Services.PlanActionService

<div class="modal-backdrop fade show"></div>
<div class="modal d-block text-white" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Title</h5>
                <button type="button" class="btn-close" @onclick="OnCancel"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@Vm" OnValidSubmit="@SaveAsync">
                    <FluentValidationValidator />
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label">Особа (Guid)</label>
                            <input class="form-control" @bind="PersonRaw" disabled="@IsEdit" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Тип</label>
                            <select class="form-select" @bind="Vm.MoveType">
                                <option value="@MoveType.Dispatch">Відрядити</option>
                                <option value="@MoveType.Return">Повернути</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Дата/час (UTC)</label>
                            <input type="datetime-local" class="form-control" @bind-value="LocalDate" @bind-value:event="oninput" />
                        </div>
                    </div>
                    <div class="row g-2 mt-1">
                        <div class="col-md-4">
                            <label class="form-label">TripId</label>
                            <input class="form-control" @bind="TripRaw" placeholder="для повернення — обов'язково" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Статус →</label>
                            <input type="number" class="form-control" @bind="Vm.ToStatusKindId" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Локація</label>
                            <input class="form-control" @bind="Vm.Location" />
                        </div>
                    </div>
                    <div class="row g-2 mt-1">
                        <div class="col-md-4">
                            <label class="form-label">Група</label>
                            <input class="form-control" @bind="Vm.GroupName" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Розрахунок</label>
                            <input class="form-control" @bind="Vm.CrewName" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Примітка</label>
                            <input class="form-control" @bind="Vm.Note" />
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button class="btn btn-primary" type="submit">Зберегти</button>
                        <button class="btn btn-secondary" type="button" @onclick="OnCancel">Скасувати</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>
