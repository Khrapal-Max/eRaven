@page "/persons"

@using eRaven.Domain.Models

<div class="container-fluid py-2 d-flex flex-column" style="gap:.5rem; min-height:70vh;">
    <!-- Toolbar -->
    <div class="d-flex align-items-center gap-2 p-2 flex-wrap justify-content-between w-100">
        <div class="flex-grow-1" style="min-width:250px; max-width:600px;">
            <SearchBox @bind-Value="Search"
                       Delay="350"
                       Placeholder="Пошук: ПІБ / РНОКПП / звання / позивний"
                       Disabled="@Busy"
                       OnSearch="OnSearchAsync" />
        </div>

        <div class="d-flex align-items-center gap-2 flex-wrap">
            <button class="btn btn-sm btn-primary"
                    title="Створити картку"
                    disabled="@Busy"
                    @onclick="CreateAsync">
                <i class="bi bi-plus-circle"></i>
                Створити
            </button>

            <button class="btn btn-sm btn-outline-secondary" disabled="@Busy" @onclick="ExportAsync">
                <i class="bi bi-file-earmark-excel"></i> Експорт
            </button>

            <button class="btn btn-sm btn-outline-secondary" disabled="@Busy" @onclick="ImportAsync">
                <i class="bi bi-upload"></i> Імпорт
            </button>
        </div>
    </div>

    @if (Items.Count > 0)
    {
        <div class="bg-dark rounded flex-grow-1 d-flex">
            <TableBaseComponent TItem="Person"
                                Class="table align-middle"
                                Items="Items"
                                SelectedItem="Selected"
                                SelectedItemChanged="(it => Selected = it)"
                                OnClick="OnRowClick">
                <TableHeader>
                    <th class="text-black">ПІБ</th>
                    <th class="text-black">Звання</th>
                    <th class="text-black">РНОКПП</th>
                    <th class="text-black">Позивний</th>
                    <th class="text-black">Посада</th>
                    <th class="text-black">Статус</th>
                    <th class="text-black"></th>
                </TableHeader>

                <RowTemplate Context="p">
                    <td>@p.FullName</td>
                    <td>@p.Rank</td>
                    <td>@p.Rnokpp</td>
                    <td>@p.Callsign</td>
                    <td>@p.PositionUnit?.ShortName</td>
                    <td class="text-center">@p.StatusKind"</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" href="@($"/person/{p.Id}")">
                            <i class="bi bi-card-text"></i> Відкрити
                        </a>
                    </td>
                </RowTemplate>
            </TableBaseComponent>
        </div>
    }
    else
    {
        <div class="h5">Список карток порожній.</div>
    }
</div>
