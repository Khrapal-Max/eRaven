@* -----------------------------------------------------------------------------
   CreatePlanModal
   - Ввести номер плану → Створити / Скасувати
   - Простий локальний валідатор (не порожній, не лише пробіли, ≤64)
   ----------------------------------------------------------------------------- *@

@using eRaven.Domain.Enums

@if (Open)
{
    <div class="modal fade show text-white" style="display:block;" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header py-2" style="background:#492448; color:#fff;">
                    <h6 class="modal-title">Новий план</h6>
                    <button type="button" class="btn-close btn-close-white"
                            aria-label="Close"
                            @onclick="Cancel" />
                </div>

                <div class="modal-body">
                    <label class="form-label text-white">Номер плану <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="_number" @bind:event="oninput" maxlength="64" />
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="text-danger small mt-1">@_error</div>
                    }
                    <div class="form-text">Номер зберігається обрізаним; максимум 64 символи.</div>
                </div>

                <div class="modal-footer py-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="Cancel">Скасувати</button>
                    <button class="btn btn-primary btn-sm"
                            @onclick="Create"
                            disabled="@(!IsValid || Busy)">
                        Створити
                    </button>
                </div>

            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}
