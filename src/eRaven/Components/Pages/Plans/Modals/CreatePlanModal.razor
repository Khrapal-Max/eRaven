@using Blazored.FluentValidation
@using eRaven.Application.ViewModels.PlanViewModels

@if (IsOpen)
{
    <div class="modal fade show d-block text-white" tabindex="-1" style="background: rgba(0,0,0,.5);" role="dialog" aria-modal="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Новий план</h5>
                    <button type="button" class="btn-close" @onclick="Close" aria-label="Close"></button>
                </div>

                <EditForm Model="_model" OnValidSubmit="CreateAsync">
                    <FluentValidationValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Номер плану</label>
                            <InputText class="form-control"
                                       @bind-Value="_model.PlanNumber"
                                       placeholder="Напр., PL-001" />
                            <ValidationMessage For="@(() => _model.PlanNumber)" />
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="Close" disabled="@_busy">Скасувати</button>
                        <button type="submit" class="btn btn-primary" disabled="@_busy">Створити</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}
