@if (Open)
{
    <div class="modal fade show text-white" style="display:block;" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered" style="max-width:520px;">
            <div class="modal-content">

                <div class="modal-header py-2">
                    <h6 class="modal-title">Створити план</h6>
                    <button type="button" class="btn-close"
                            aria-label="Close"
                            @onclick="OnCancelClicked" />
                </div>

                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Номер/назва плану</label>
                        <input class="form-control form-control-sm"
                               placeholder="Напр.: П-23/09"
                               @bind-Value="_number"
                               @bind-Value:event="oninput"
                               maxlength="64"
                               autofocus />
                        <div class="form-text">
                            2–64 символи. Лишні пробіли буде обрізано.
                        </div>
                    </div>

                    @if (_error is not null)
                    {
                        <div class="alert alert-danger py-1 mb-0">@_error</div>
                    }
                </div>

                <div class="modal-footer py-2">
                    <button class="btn btn-secondary btn-sm"
                            type="button"
                            @onclick="OnCancelClicked"
                            disabled="@Busy">
                        Скасувати
                    </button>

                    <button class="btn btn-primary btn-sm"
                            type="button"
                            @onclick="OnCreateClicked"
                            disabled="@IsCreateDisabled">
                        Створити
                    </button>
                </div>

            </div>
        </div>
    </div>
}
