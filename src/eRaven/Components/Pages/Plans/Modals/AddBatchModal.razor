@* @using eRaven.Domain.Enums
@if (_open)
{
    <div class="modal fade show text-white" style="display:block;" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Пакет дій</h6>
                    <button type="button" class="btn-close" @onclick="Cancel"></button>
                </div>

                <div class="modal-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="small text-muted">План: <span class="text-info">@_planNumber</span></div>
                        <div>
                            <button class="btn btn-sm btn-outline-success" @onclick="AddRow" disabled="@_busy">
                                <i class="bi bi-plus-circle"></i> Додати рядок
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width:220px;">Особа</th>
                                    <th style="width:120px;">Дія</th>
                                    <th style="width:180px;">Коли (лок.)</th>
                                    <th>Локація</th>
                                    <th>Група</th>
                                    <th>Екіпаж</th>
                                    <th>Примітка</th>
                                    <th style="width:40px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < _rows.Count; i++)
                                {
                                    var r = _rows[i];
                                    <tr>
                                        <td>
                                            <select class="form-select form-select-sm" @bind="r.PersonId" disabled="@_busy">
                                                <option value="">— Оберіть —</option>
                                                @foreach (var p in _people)
                                                {
                                                    <option value="@p.Id">@p.FullName (@p.Rank)</option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm" @bind="r.ActionType" disabled="@_busy">
                                                <option value="@PlanActionType.Dispatch">Відрядити</option>
                                                <option value="@PlanActionType.Return">Повернути</option>
                                            </select>
                                        </td>
                                        <td>
                                            <input type="datetime-local" class="form-control form-control-sm"
                                                   @bind="r.WhenLocal"
                                                   disabled="@_busy" />
                                        </td>
                                        <td><input class="form-control form-control-sm" @bind="r.Location" maxlength="128" disabled="@_busy" /></td>
                                        <td><input class="form-control form-control-sm" @bind="r.Group" maxlength="128" disabled="@_busy" /></td>
                                        <td><input class="form-control form-control-sm" @bind="r.Crew" maxlength="128" disabled="@_busy" /></td>
                                        <td><input class="form-control form-control-sm" @bind="r.Note" maxlength="512" disabled="@_busy" /></td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-danger" title="Видалити рядок" @onclick="() => RemoveRow(i)" disabled="@_busy">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                                @if (_rows.Count == 0)
                                {
                                    <tr><td colspan="8" class="text-center text-muted">Рядків немає — додайте щонайменше один.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_error))
                    {
                        <div class="alert alert-danger py-1 mt-2 mb-0">@_error</div>
                    }
                </div>

                <div class="modal-footer py-2">
                    <button class="btn btn-secondary btn-sm" @onclick="Cancel" disabled="@_busy">Скасувати</button>
                    <button class="btn btn-primary btn-sm" @onclick="Save" disabled="@IsDisabled">Зберегти пакет</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
} *@