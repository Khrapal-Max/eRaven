@using Blazored.FluentValidation
@using eRaven.Application.ViewModels.PlanViewModels
@using eRaven.Application.ViewModels.PersonViewModels
@using eRaven.Domain.Enums

@if (_open && !ReadOnly)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,.5);" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Додати дію</h5>
                    <button type="button" class="btn-close" @onclick="Close" aria-label="Close"></button>
                </div>

                <EditForm Model="_model" OnValidSubmit="CreateAsync">
                    <FluentValidationValidator />
                    <div class="modal-body">

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Особа</label>
                                <div class="input-group">
                                    <input class="form-control" placeholder="ПІБ або РНОКПП" @bind="_personQuery" @bind:event="oninput" />
                                    <button class="btn btn-outline-secondary" type="button" @onclick="SearchPersons">Шукати</button>
                                </div>

                                @if (_personResults?.Count > 0)
                                {
                                    <div class="list-group mt-2" style="max-height: 180px; overflow:auto">
                                        @foreach (var pr in _personResults)
                                        {
                                            <button type="button" class="list-group-item list-group-item-action"
                                                    @onclick="@(() => SelectPerson(pr))">
                                                <div class="fw-semibold">@pr.FullName</div>
                                                <small class="text-muted">@pr.Rnokpp · @pr.Rank · @pr.PositionName</small>
                                            </button>
                                        }
                                    </div>
                                }

                                @if (_selectedPerson is not null)
                                {
                                    <div class="alert alert-secondary mt-2 py-2">
                                        Обрано: <strong>@_selectedPerson.FullName</strong> (@_selectedPerson.Rnokpp),
                                        @_selectedPerson.Rank, @_selectedPerson.PositionName
                                    </div>
                                }
                                <ValidationMessage For="@(() => _model.PersonId)" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Дія</label>
                                <InputSelect class="form-select" @bind-Value="_model.ActionType">
                                    <option value="@PlanActionType.Dispatch">Dispatch</option>
                                    <option value="@PlanActionType.Return">Return</option>
                                </InputSelect>

                                <label class="form-label mt-3">Час (UTC)</label>
                                <input type="datetime-local" class="form-control"
                                       @bind-value="_eventLocal"
                                       @bind-value:format="yyyy-MM-ddTHH:mm" />

                                <label class="form-label mt-3">Локація</label>
                                <InputText class="form-control" @bind-Value="_model.Location" />
                                <ValidationMessage For="@(() => _model.Location)" />

                                <div class="row g-2 mt-3">
                                    <div class="col">
                                        <label class="form-label">Група</label>
                                        <InputText class="form-control" @bind-Value="_model.GroupName" />
                                        <ValidationMessage For="@(() => _model.GroupName)" />
                                    </div>
                                    <div class="col">
                                        <label class="form-label">Зміна</label>
                                        <InputText class="form-control" @bind-Value="_model.CrewName" />
                                        <ValidationMessage For="@(() => _model.CrewName)" />
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="Close" disabled="@_busy">Скасувати</button>
                        <button type="submit" class="btn btn-primary" disabled="@_busy || _model.PersonId == Guid.Empty">Додати</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}
