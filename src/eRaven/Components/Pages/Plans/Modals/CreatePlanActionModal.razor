@using Blazored.FluentValidation
@using eRaven.Application.ViewModels.PlanViewModels
@using eRaven.Application.ViewModels.PersonViewModels
@using eRaven.Domain.Enums
@using eRaven.Components.Shared.TableBaseComponent

@if (_open && !ReadOnly)
{
    <div class="modal fade show d-block text-white" tabindex="-1" style="background: rgba(0,0,0,.5);" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Додати дію</h5>
                    <button type="button" class="btn-close" @onclick="Close" aria-label="Close"></button>
                </div>

                <EditForm Model="_model" OnValidSubmit="CreateAsync">
                    <FluentValidationValidator />

                    <div class="modal-body">

                        <!-- Верх: 2 візуальні ряди з фіксованими місцями під помилки -->
                        <div class="card mb-3">
                            <div class="card-body py-3">
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-3">
                                        <label class="form-label">Дія</label>
                                        <InputSelect class="form-select" @bind-Value="_model.ActionType" @onchange="OnActionTypeChanged">
                                            <option value="@PlanActionType.Dispatch">Відрядити</option>
                                            <option value="@PlanActionType.Return">Повернути</option>
                                        </InputSelect>
                                        <div class="form-text" style="min-height: 1.25rem;"></div>
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label">Час (UTC)</label>
                                        <input type="datetime-local"
                                               class="form-control"
                                               step="900"
                                               @bind="_eventLocal"
                                               @bind:format="yyyy-MM-ddTHH:mm" />
                                        <div class="form-text" style="min-height: 1.25rem;">
                                            <ValidationMessage For="@(() => _model.EventAtUtc)" />
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label">Локація</label>
                                        <InputText class="form-control" @bind-Value="_model.Location" />
                                        <div class="form-text" style="min-height: 1.25rem;">
                                            <ValidationMessage For="@(() => _model.Location)" />
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label">Група</label>
                                        <InputText class="form-control" @bind-Value="_model.GroupName" />
                                        <div class="form-text" style="min-height: 1.25rem;">
                                            <ValidationMessage For="@(() => _model.GroupName)" />
                                        </div>
                                    </div>
                                </div>

                                <div class="row g-3 align-items-end mt-1">
                                    <div class="col-md-3">
                                        <label class="form-label">Зміна</label>
                                        <InputText class="form-control" @bind-Value="_model.CrewName" />
                                        <div class="form-text" style="min-height: 1.25rem;">
                                            <ValidationMessage For="@(() => _model.CrewName)" />
                                        </div>
                                    </div>

                                    <div class="col-md-9">
                                        <!-- Порожнє місце, щоб форма не "плавала" при повідомленнях -->
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Низ: пошук + список кандидатів (eligible/ineligible) -->
                        <div class="card">
                            <div class="card-header d-flex align-items-center gap-2 flex-wrap">
                                <span>Обрати особу</span>
                                <div class="ms-auto d-flex gap-2 align-items-center">
                                    <input class="form-control form-control-sm"
                                           style="min-width:320px"
                                           placeholder="ПІБ або РНОКПП"
                                           @bind="_personQuery"
                                           @bind:event="oninput"
                                           @onkeydown="@(e => { if (e.Key == "Enter") _ = SearchPersonsAsync(); })" />
                                    <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="SearchPersonsAsync">Шукати</button>
                                </div>
                            </div>

                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-5">
                                        @if (_selectedPerson is not null)
                                        {
                                            <div class="alert alert-secondary py-2">
                                                <div><strong>@_selectedPerson.FullName</strong> (@_selectedPerson.Rnokpp)</div>
                                                <div class="small">Звання: @_selectedPerson.Rank</div>
                                                <div class="small">Посада: @_selectedPerson.PositionFullName</div>
                                                <div class="small">БЗВП: @_selectedPerson.BZVP</div>
                                                <div class="small">Зброя: @(string.IsNullOrWhiteSpace(_selectedPerson.Weapon) ? "—" : _selectedPerson.Weapon)</div>
                                                <div class="small">Позивний: @(string.IsNullOrWhiteSpace(_selectedPerson.Callsign) ? "—" : _selectedPerson.Callsign)</div>
                                            </div>
                                        }
                                        <ValidationMessage For="@(() => _model.PersonId)" />
                                    </div>

                                    <div class="col-md-7">
                                        @if (_eligible.Count == 0 && _ineligible.Count == 0)
                                        {
                                            <div class="text-muted">Введіть запит і натисніть «Шукати»…</div>
                                        }
                                        else
                                        {
                                            <div class="mb-2">
                                                <span class="badge bg-success me-2">Доступні: @_eligible.Count</span>
                                                <span class="badge bg-secondary">Недоступні: @_ineligible.Count</span>
                                            </div>

                                            <TableBaseComponent TItem="PersonEligibilityViewModel"
                                                                Class="table-sm align-middle"
                                                                Items="_eligible.Concat(_ineligible).ToList()"
                                                                SelectedItem="_selectedPerson"
                                                                SelectedItemChanged="@(p => _selectedPerson = p)"
                                                                OnClick="SelectPersonAsync"
                                                                MaxHeight="300px"
                                                                MinHeight="220px">
                                                <TableHeader>
                                                    <th class="text-black" scope="col">ПІБ</th>
                                                    <th class="text-black" scope="col">РНОКПП</th>
                                                    <th class="text-black" scope="col">Звання</th>
                                                    <th class="text-black" scope="col">Посада</th>
                                                    <th class="text-black" scope="col">БЗВП</th>
                                                    <th class="text-black" scope="col">Зброя</th>
                                                    <th class="text-black" scope="col">Позивний</th>
                                                    <th class="text-black" scope="col" style="width:1%"></th>
                                                </TableHeader>

                                                <RowTemplate Context="p">
                                                    <td>@p.FullName</td>
                                                    <td>@p.Rnokpp</td>
                                                    <td>@p.Rank</td>
                                                    <td>@p.PositionFullName</td>
                                                    <td>@p.BZVP</td>
                                                    <td>@(string.IsNullOrWhiteSpace(p.Weapon) ? "—" : p.Weapon)</td>
                                                    <td>@(string.IsNullOrWhiteSpace(p.Callsign) ? "—" : p.Callsign)</td>
                                                    <td class="text-end">
                                                        @if (p.IsEligible)
                                                        {
                                                            <span class="badge bg-success">можна</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-danger"
                                                                  title="@p.IneligibilityReason">ні</span>
                                                        }
                                                    </td>
                                                </RowTemplate>
                                            </TableBaseComponent>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="Close" disabled="@_busy">Скасувати</button>
                        <button type="submit" class="btn btn-primary" disabled="@_busy">Додати</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}
