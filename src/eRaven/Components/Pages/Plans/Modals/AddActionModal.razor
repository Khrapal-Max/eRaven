@using eRaven.Domain.Enums
@using eRaven.Domain.Models
@using Blazored.FluentValidation

@if (_open)
{
    <div class="modal fade show text-white" style="display:block;" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered" style="max-width:680px;">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Додати дію</h6>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="Cancel"></button>
                </div>

                <EditForm Model="Model" OnValidSubmit="SubmitAsync">
                    <AntiforgeryToken />
                    <FluentValidationValidator />
                    <div class="modal-body">
                        <ValidationSummary class="text-danger small mb-2" />

                        <div class="row g-2">
                            <div class="col-12 col-md-6">
                                <label class="form-label">Особа</label>
                                <InputSelect class="form-select form-select-sm"
                                             @bind-Value="Model.PersonId"
                                             disabled="@_busy">
                                    <option value="">— Оберіть —</option>
                                    @foreach (var p in _people)
                                    {
                                        <option value="@p.Id">@p.FullName (@p.Rank)</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => Model.PersonId)" />
                            </div>

                            <div class="col-6 col-md-3">
                                <label class="form-label">Дія</label>
                                <InputSelect class="form-select form-select-sm"
                                             @bind-Value="Model.ActionType"
                                             disabled="@_busy">
                                    <option value="@PlanActionType.Dispatch">Відрядити</option>
                                    <option value="@PlanActionType.Return">Повернути</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => Model.ActionType)" />
                            </div>

                            <div class="col-6 col-md-3">
                                <label class="form-label">Коли</label>
                                <input type="datetime-local"
                                       class="form-control form-control-sm"
                                       @bind-value="_whenLocal"
                                       @bind-value:event="oninput"
                                       disabled="@_busy" />
                                <div class="form-text">Локальний час (перед збереженням конвертуємо)</div>
                                <ValidationMessage For="@(() => Model.EventAtUtc)" />
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label">Локація</label>
                                <InputText class="form-control form-control-sm"
                                           @bind-Value="Model.Location"
                                           disabled="@_busy" />
                                <ValidationMessage For="@(() => Model.Location)" />
                            </div>

                            <div class="col-6 col-md-4">
                                <label class="form-label">Група</label>
                                <InputText class="form-control form-control-sm"
                                           @bind-Value="Model.GroupName"
                                           disabled="@_busy"/>
                                <ValidationMessage For="@(() => Model.GroupName)" />
                            </div>

                            <div class="col-6 col-md-4">
                                <label class="form-label">Екіпаж</label>
                                <InputText class="form-control form-control-sm"
                                           @bind-Value="Model.CrewName"
                                           disabled="@_busy" />
                                <ValidationMessage For="@(() => Model.CrewName)" />
                            </div>

                            <div class="col-12">
                                <label class="form-label">Примітка</label>
                                <InputText class="form-control form-control-sm"
                                           @bind-Value="Model.Note"
                                           disabled="@_busy"/>
                                <ValidationMessage For="@(() => Model.Note)" />
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-secondary btn-sm" @onclick="Cancel" disabled="@_busy">Скасувати</button>
                        <button type="submit" class="btn btn-primary btn-sm" disabled="@_busy">
                            @if (_busy)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Зберегти
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}
