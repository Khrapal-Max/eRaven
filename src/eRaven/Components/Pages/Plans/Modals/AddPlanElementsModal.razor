@* -----------------------------------------------------------------------------
   AddPlanElementsModal (2-step wizard)
   - Крок 1: атрибути елемента (єдиний стан форми: CreatePlanElementViewModel)
   - Крок 2: відбір і мульти-вибір людей
   - Батьку повертаємо IReadOnlyList<CreatePlanElementViewModel> (1-елемент = 1-особа)
   ----------------------------------------------------------------------------- *@

@using eRaven.Domain.Enums
@using eRaven.Domain.Models
@using eRaven.Application.ViewModels.PlanViewModels

@if (Open)
{
    <div class="modal fade show text-white" style="display:block;" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header py-2" style="background: var(--ng-bg, #492448); color:#fff;">
                    <h6 class="modal-title">
                        Додати елемент плану
                        <small class="ms-2 opacity-75">(@(_step == Step.Attributes ? "Крок 1/2" : "Крок 2/2"))</small>
                    </h6>
                    <button type="button" class="btn-close btn-close-white"
                            aria-label="Close"
                            @onclick="CloseAndReset"
                            @onclick:preventDefault="true"
                            @onclick:stopPropagation="true" />
                </div>

                <!-- Body -->
                <div class="modal-body" style="min-height: 58vh;">
                    @if (_step == Step.Attributes)
                    {
                        <!-- КРОК 1: Атрибути -->
                        <div class="row g-3">
                            <div class="col-12 col-lg-5">
                                <div class="mb-2 fw-semibold">Атрибути елемента</div>
                                <div class="row g-2">
                                    <div class="col-12">
                                        <label class="form-label">Дія</label>
                                        <select class="form-select form-select-sm"
                                                value="@((int)_form.Type)"
                                                @onchange="OnTypeChanged">
                                            <option value="@((int)PlanType.Dispatch)">Відрядити</option>
                                            <option value="@((int)PlanType.Return)">Повернути</option>
                                        </select>
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Дата</label>
                                        <input class="form-control form-control-sm" type="date" @bind="_date" />
                                    </div>

                                    <div class="col-6">
                                        <label class="form-label">Година</label>
                                        <select class="form-select form-select-sm" @bind="_hour">
                                            @for (var h = 0; h < 24; h++)
                                            {
                                                <option value="@h">@h.ToString("00")</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Хвилини</label>
                                        <select class="form-select form-select-sm" @bind="_minute">
                                            <option value="0">00</option>
                                            <option value="15">15</option>
                                            <option value="30">30</option>
                                            <option value="45">45</option>
                                        </select>
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Локація</label>
                                        <input class="form-control form-control-sm"
                                               @bind="_form.Location"
                                               disabled="@IsReturn" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Група</label>
                                        <input class="form-control form-control-sm"
                                               @bind="_form.GroupName"
                                               disabled="@IsReturn" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Екіпаж</label>
                                        <input class="form-control form-control-sm"
                                               @bind="_form.ToolType"
                                               disabled="@IsReturn" />
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Нотатка</label>
                                        <input class="form-control form-control-sm" @bind="_form.Note" />
                                    </div>
                                </div>

                                @if (_errors.Count > 0)
                                {
                                    <div class="alert alert-warning mt-3 mb-0 py-2">
                                        <ul class="mb-0 small">
                                            @foreach (var e in _errors)
                                            {
                                                <li>@e</li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </div>

                            <div class="col-12 col-lg-7">
                                <div class="alert alert-info mb-0 small">
                                    Задайте спільні атрибути елемента. На наступному кроці оберете людей.
                                    <div class="mt-2">
                                        <b>Валідація:</b> хвилини 00/15/30/45; для «Відрядити» бажано вказати локацію.
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- КРОК 2: Вибір людей -->
                        <div class="row g-3">
                            <div class="col-12 col-lg-4">
                                <div class="card h-100">
                                    <div class="card-header py-2">Додані (@_selected.Count)</div>
                                    <div class="card-body py-2">
                                        @if (_selected.Count == 0)
                                        {
                                            <div class="small text-muted">Поки порожньо.</div>
                                        }
                                        else
                                        {
                                            <ul class="list-group list-group-flush">
                                                @foreach (var item in _selected.Select(id => People.FirstOrDefault(x => x.Id == id)).Where(x => x is not null))
                                                {
                                                    <li class="list-group-item d-flex align-items-center justify-content-between">
                                                        <span class="badge rounded-pill text-bg-light px-3 py-2 fw-semibold text-truncate" style="max-width: 220px;">
                                                            @(item!.FullName ?? $"{item!.LastName} {item!.FirstName} {item!.MiddleName}")
                                                        </span>
                                                        <button class="btn btn-sm btn-outline-light" title="Прибрати" @onclick="() => RemovePick(item!.Id)">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-8 d-flex flex-column" style="gap:.5rem;">
                                <div class="d-flex align-items-center gap-2">
                                    <input class="form-control form-control-sm"
                                           placeholder="Пошук: ПІБ / ІПН / звання / посада"
                                           @bind="_query" @bind:event="oninput" />
                                    <button type="button" class="btn btn-sm btn-primary" @onclick="ApplyPeopleFilter">
                                        Шукати
                                    </button>
                                </div>

                                <div class="table-responsive" style="max-height:48vh;">
                                    <table class="table table-sm table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="text-black">ПІБ / ІПН / Посада</th>
                                                <th class="text-black text-center">Статус</th>
                                                <th class="text-black text-center">Додати</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (_candidates.Count == 0)
                                            {
                                                <tr><td colspan="3" class="text-muted">Нічого не знайдено або ніхто не підходить під правила.</td></tr>
                                            }
                                            else
                                            {
                                                @foreach (var p in _candidates)
                                                {
                                                    var disabled = _selected.Contains(p.Id) || IsDuplicateAtThisTime(p.Id, BuildEventUtc());
                                                    <tr>
                                                        <td style="max-width:360px;">
                                                            <div class="fw-semibold text-truncate" title="@(p.FullName ?? $"{p.LastName} {p.FirstName} {p.MiddleName}")">
                                                                @(p.FullName ?? $"{p.LastName} {p.FirstName} {p.MiddleName}")
                                                            </div>
                                                            <div class="small text-secondary">@p.Rnokpp</div>
                                                            @if (!string.IsNullOrWhiteSpace(p.PositionUnit?.FullName ?? p.PositionUnit?.ShortName))
                                                            {
                                                                <div class="small text-secondary text-truncate"
                                                                     title="@(p.PositionUnit?.FullName ?? p.PositionUnit?.ShortName)">
                                                                    @(p.PositionUnit?.FullName ?? p.PositionUnit?.ShortName)
                                                                </div>
                                                            }
                                                        </td>
                                                        <td class="text-center">
                                                            <span class="badge text-bg-light">@(!string.IsNullOrWhiteSpace(p.StatusKind?.Name) ? p.StatusKind!.Name : p.StatusKind?.Code)</span>
                                                        </td>
                                                        <td class="text-center">
                                                            <button class="btn btn-sm @(disabled ? "btn-outline-secondary" : "btn-success")"
                                                                    title="@(disabled ? "Вже додано / дубль у цей момент" : "Додати")"
                                                                    disabled="@disabled"
                                                                    @onclick="() => AddPick(p.Id)">
                                                                <i class="bi @(disabled ? "bi-check-lg" : "bi-plus-lg")"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Footer -->
                <div class="modal-footer py-2" style="border-top-color: var(--ng-bg, #492448);">
                    @if (_step == Step.Attributes)
                    {
                        <div class="small text-secondary me-auto">
                            Порада: для «Повернути» контекст (локація/група/екіпаж) підставить бек із попереднього «Відрядити».
                        </div>

                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CloseAndReset">Скасувати</button>
                        <button type="button" class="btn btn-primary btn-sm" @onclick="Next" disabled="@(!Validate(false))">Далі</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="Back">Назад</button>
                        <button type="button" class="btn btn-success btn-sm" @onclick="Submit" disabled="@(_selected.Count == 0)">Додати елемент</button>
                    }
                </div>
            </div>
        </div>
    </div>
}
