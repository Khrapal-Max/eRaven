@* -----------------------------------------------------------------------------
   AddPlanElementsModal (view)
   - Крок 1: атрибути (тип, дата/час квартильний, опціональні поля для Dispatch, нотатка)
   - Крок 2: список людей з пошуком і відбором за правилами (простими)
   - Обидва кроки однакової ширини/висоти (fixed layout)
   ----------------------------------------------------------------------------- *@

@using eRaven.Domain.Enums
@using eRaven.Domain.Models
@using eRaven.Application.ViewModels.PlanViewModels

@if (Open)
{
    <div class="modal fade show text-white" style="display:block;" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
            <div class="modal-content">

                <div class="modal-header py-2" style="background:#492448;">
                    <h6 class="modal-title">Додати елемент плану</h6>
                    <button type="button" class="btn-close btn-close-white" aria-label="Close"
                            @onclick="CloseAndReset"></button>
                </div>

                <div class="modal-body">
                    <div class="row g-3" style="min-height:52vh;">
                        @if (Step == WizardStep.Attributes)
                        {
                            <div class="col-12 col-lg-6">
                                <div class="row g-2">
                                    <div class="col-12">
                                        <label class="form-label">Дія</label>
                                        <select class="form-select form-select-sm" @bind="_type" @bind:after="OnTypeChanged">
                                            <option value="@PlanType.Dispatch">Відрядити</option>
                                            <option value="@PlanType.Return">Повернути</option>
                                        </select>
                                    </div>

                                    <div class="col-6">
                                        <label class="form-label">Дата</label>
                                        <input class="form-control form-control-sm" type="date" @bind="_date" />
                                    </div>
                                    <div class="col-3">
                                        <label class="form-label">Година</label>
                                        <select class="form-select form-select-sm" @bind="_hour">
                                            @for (var h = 0; h < 24; h++)
                                            { <option value="@h">@h.ToString("00")</option> }
                                        </select>
                                    </div>
                                    <div class="col-3">
                                        <label class="form-label">Хвилини</label>
                                        <select class="form-select form-select-sm" @bind="_minute">
                                            <option value="0">00</option>
                                            <option value="15">15</option>
                                            <option value="30">30</option>
                                            <option value="45">45</option>
                                        </select>
                                    </div>

                                    @if (_type == PlanType.Dispatch)
                                    {
                                        <div class="col-12">
                                            <label class="form-label">Локація</label>
                                            <input class="form-control form-control-sm" @bind="_location" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Група</label>
                                            <input class="form-control form-control-sm" @bind="_group" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Екіпаж</label>
                                            <input class="form-control form-control-sm" @bind="_tool" />
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 d-flex flex-column">
                                <div class="flex-grow-1">
                                    <label class="form-label">Нотатка</label>
                                    <textarea class="form-control" rows="8" @bind="_note"></textarea>
                                </div>

                                @if (_attrErrors.Count > 0)
                                {
                                    <ul class="mt-2 small text-warning">
                                        @foreach (var e in _attrErrors) { <li>@e</li> }
                                    </ul>
                                }
                            </div>

                            <div class="col-12">
                                <div class="small text-secondary">
                                    Порада: плануйте від старших до молодших часових слотів. Дії в межах плану для кожної особи мають чергуватися.
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="col-12 col-lg-4">
                                <div class="card h-100">
                                    <div class="card-header py-2">Додані (@_selected.Count)</div>
                                    <div class="card-body py-2">
                                        @if (_selected.Count == 0)
                                        {
                                            <div class="small text-muted">Поки порожньо.</div>
                                        }
                                        else
                                        {
                                            <ul class="list-group list-group-flush">
                                                @foreach (var item in _selected.Select(id => People.FirstOrDefault(x => x.PersonId == id)).Where(x => x is not null))
                                                {
                                                    <li class="list-group-item d-flex align-items-center justify-content-between">
                                                        <span class="text-truncate" style="max-width:16rem;" title="@item!.FullName">@item!.FullName</span>
                                                        <button class="btn btn-sm btn-outline-dark" title="Прибрати" @onclick="() => RemovePick(item!.PersonId)">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-8 d-flex flex-column" style="gap:.5rem;">
                                <div class="d-flex align-items-center gap-2">
                                    <input class="form-control form-control-sm" placeholder="Пошук: ПІБ / ІПН / звання / посада"
                                           @bind="_query" @bind:event="oninput" />
                                    <button class="btn btn-sm btn-primary" @onclick="OnSearchClick">Шукати</button>
                                </div>

                                <div class="table-responsive" style="max-height:44vh;">
                                    <table class="table table-sm table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="text-black">ПІБ / ІПН / Посада</th>
                                                <th class="text-black text-center">Статус</th>
                                                <th class="text-black text-center">Дія</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (_candidates.Count == 0)
                                            {
                                                <tr><td colspan="3" class="text-muted">Нічого не знайдено або ніхто не підходить.</td></tr>
                                            }
                                            else
                                            {
                                                @foreach (var p in _candidates)
                                                {
                                                    var disabled = _selected.Contains(p.PersonId) || IsDuplicateAtSameMoment(p.PersonId);
                                                    <tr>
                                                        <td>
                                                            <div class="fw-semibold text-truncate" style="max-width:22rem;" title="@p.FullName">@p.FullName</div>
                                                            <div class="small text-secondary">@p.Rnokpp</div>
                                                            @if (!string.IsNullOrWhiteSpace(p.Position))
                                                            { <div class="small text-secondary">@p.Position</div> }
                                                        </td>
                                                        <td class="text-center">
                                                            <span class="badge text-bg-light">@(!string.IsNullOrWhiteSpace(p.StatusKindName) ? p.StatusKindName : p.StatusKindCode)</span>
                                                        </td>
                                                        <td class="text-center">
                                                            <button class="btn btn-sm @(disabled ? "btn-outline-secondary" : "btn-success")"
                                                                    title="@(disabled ? "Вже є дія на цей час" : "Додати")"
                                                                    disabled="@disabled"
                                                                    @onclick="() => AddPick(p.PersonId)">
                                                                <i class="bi @(disabled ? "bi-check-lg" : "bi-plus-lg")"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="modal-footer py-2" style="border-top-color:#492448;">
                    @if (Step == WizardStep.Attributes)
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CloseAndReset">Скасувати</button>
                        <button type="button" class="btn btn-primary btn-sm" @onclick="GoNext" disabled="@(!CanGoNext())">Далі</button>
                    }
                    else
                    {
                        <div class="small me-auto text-secondary">
                            Обрано: @_selected.Count
                        </div>
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoBack">Назад</button>
                        <button type="button" class="btn btn-success btn-sm" @onclick="Submit" disabled="@(_selected.Count == 0)">Додати елемент</button>
                    }
                </div>

            </div>
        </div>
    </div>
}
