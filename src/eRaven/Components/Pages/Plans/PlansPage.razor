@page "/plans"

@using eRaven.Domain.Enums
@using eRaven.Application.ViewModels.PlanViewModels
@using eRaven.Components.Shared.TableBaseComponent
@using eRaven.Components.Pages.Plans.Modals


<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="m-0 fw-bold">Плани</h5>
    <div class="btn-toolbar gap-2">
        <a class="btn btn-success text-nowrap" href="/orders/publish">Опублікувати добовий наказ</a>
        <button class="btn btn-primary text-nowrap" @onclick="OpenCreateModal">Новий план</button>
    </div>
</div>

<TableBaseComponent TItem="PlanViewModel"
                    Class="align-middle"
                    Items="_plans"
                    SelectedItem="_selected"
                    SelectedItemChanged="OnSelectedChanged"
                    OnClick="OnRowClick"
                    MaxHeight="80vh"
                    MinHeight="300px">
    <TableHeader>
        <th class="text-black" scope="col">Номер</th>
        <th class="text-black" scope="col">Стан</th>
        <th class="text-black" scope="col">Автор</th>
        <th class="text-black" scope="col">Створено (UTC)</th>
        <th class="text-black" scope="col">Наказ</th>
        <th class="text-black" scope="col" style="width:180px"></th>
    </TableHeader>

    <RowTemplate Context="p">
        <td class="@((p.State == PlanState.Close) ? "table-success" : null) text-center">@p.PlanNumber</td>
        <td class="text-center">@p.State</td>
        <td class="text-center">@p.Author</td>
        <td class="text-center">@p.RecordedUtc.ToString("dd.MM.yyyy HH:mm")</td>
        <td class="text-center">
            @if (p.OrderId is Guid oid)
            {
                <a class="link" href="@($"/orders/{oid}")">@oid.ToString()[..8]…</a>
            }
            else
            {
                <span class="text-muted">Очікує наказу</span>
            }
        </td>
        <td class="text-end">
            <a class="btn btn-sm btn-outline-primary me-2"
               href="@($"/plans/{p.Id}")"
               @onclick:stopPropagation="true">Деталі</a>

            <button class="btn btn-sm btn-outline-danger"
                    @onclick="(e) => DeleteAsync(p.Id)"
                    @onclick:stopPropagation="true"
                    disabled="@(_busy || p.State == PlanState.Close || p.OrderId != null)">
                Видалити
            </button>
        </td>
    </RowTemplate>
</TableBaseComponent>

@if (_loading)
{
    <div class="p-3 text-muted">Завантаження…</div>
}
else if (_plans.Count == 0)
{
    <div class="p-3 text-muted">Немає планів</div>
}

<CreatePlanModal @ref="_createModal"
                 IsOpen="_createOpen"
                 OnClose="CloseCreateModal"
                 OnCreated="HandleCreated" />
