@* -----------------------------------------------------------------------------
   PlansPage (view)
   - Пошук по номеру
   - Список планів
   - Створення плану (inline modal)
   ----------------------------------------------------------------------------- *@

@page "/plans"

@using eRaven.Domain.Enums
@using eRaven.Domain.Models

<PageTitle>Плани</PageTitle>

<div class="container-fluid py-2 d-flex flex-column" style="gap:.5rem; min-height:70vh;">

    <div class="d-flex align-items-center gap-2 p-1 flex-wrap justify-content-between w-100">
        <div class="flex-grow-1" style="min-width:260px; max-width:600px;">
            <SearchBox @bind-Value="Search"
                       Delay="350"
                       Placeholder="Пошук за номером плану…"
                       Disabled="@Busy"
                       OnSearch="OnSearchAsync" />
        </div>

        <button class="btn btn-sm btn-primary"
                @onclick="OpenCreateModal"
                disabled="@Busy"
                title="Створити план">
            <i class="bi bi-plus-circle me-1"></i> Створити план
        </button>
    </div>

    @if (_view.Any())
    {
        <div class="bg-dark rounded flex-grow-1 d-flex">
            <TableBaseComponent Items="_view"
                                TItem="Plan"
                                Class="table align-middle mb-0">
                <TableHeader>
                    <th class="text-black text-center">№ плану</th>
                    <th class="text-black text-center">Дата запису</th>
                    <th class="text-black text-center">Стан</th>
                    <th class="text-black text-center">Автор</th>
                    <th class="text-black text-center">Дії</th>
                </TableHeader>

                <RowTemplate Context="p">
                    <td class="text-center">
                        <a href="@($"/plans/{p.Id:D}")" class="text-decoration-none">@p.PlanNumber</a>
                    </td>
                    <td class="text-center">@p.RecordedUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="text-center">
                        @if (p.State == PlanState.Open)
                        {
                            <span class="badge text-bg-success">Відкритий</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Закритий</span>
                        }
                    </td>
                    <td class="text-center">@p.Author</td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-danger" title="Видалити"
                                @onclick="() => DeletePlanAsync(p)"
                                disabled="@Busy || p.State != PlanState.Open">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </RowTemplate>
            </TableBaseComponent>
        </div>
    }
    else
    {
        <div class="h5 px-2">@((Busy ? "Завантаження…" : "Плани відсутні або нічого не знайдено."))</div>
    }
</div>

@* Inline Create Modal *@
@if (_createOpen)
{
    <div class="modal fade show text-white" style="display:block;" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header py-2">
                    <h6 class="modal-title">Створити план</h6>
                    <button type="button" class="btn-close" @onclick="CloseCreateModal"></button>
                </div>

                <div class="modal-body">
                    <label class="form-label">Номер плану</label>
                    <input class="form-control" @bind="_newPlanNumber" />
                </div>

                <div class="modal-footer py-2">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseCreateModal">Скасувати</button>
                    <button class="btn btn-primary btn-sm" @onclick="CreatePlanAsync" disabled="@Busy || string.IsNullOrWhiteSpace(_newPlanNumber)">Створити</button>
                </div>

            </div>
        </div>
    </div>
}
