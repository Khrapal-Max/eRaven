   -----------------------------------------------------------------------------
   PlansPage (view)
   - Пошук за номером плану
   - Список планів (без include)
   - Кнопка створення плану
   - Посилання на сторінку деталізації плану
   ----------------------------------------------------------------------------- *@

@page "/plans"

@using eRaven.Domain.Enums
@using eRaven.Domain.Models

<PageTitle>Плани</PageTitle>

<div class="container-fluid py-2 d-flex flex-column" style="gap:.5rem; min-height:70vh;">

    <!-- Пошук + кнопка створення -->
    <div class="d-flex align-items-center gap-2 p-1 flex-wrap justify-content-between w-100">
        <div class="flex-grow-1" style="min-width:260px; max-width:600px;">
            <SearchBox @bind-Value="Search"
                       Delay="350"
                       Placeholder="Пошук за номером плану…"
                       Disabled="@Busy"
                       OnSearch="OnSearchAsync" />
        </div>

        <button class="btn btn-sm btn-primary" @onclick="GoCreate" disabled="@Busy" title="Створити план">
            <i class="bi bi-plus-circle me-1"></i> Створити план
        </button>
    </div>

    <!-- Таблиця -->
    @if (_view.Any())
    {
        <div class="bg-dark rounded flex-grow-1 d-flex">
            <TableBaseComponent Items="_view"
                                TItem="Plan"
                                Class="table align-middle mb-0">
                <TableHeader>
                    <th class="text-black">№ плану</th>
                    <th class="text-black text-center">Дата запису</th>
                    <th class="text-black text-center">Стан</th>
                    <th class="text-black">Автор</th>
                </TableHeader>

                <RowTemplate Context="p">
                    <td>
                        <a class="link-primary text-decoration-none"
                           href="@PlanDetailsHref(p.Id)"
                           title="Відкрити план">
                            @p.PlanNumber
                        </a>
                    </td>
                    <td class="text-center">@p.RecordedUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="text-center">
                        @switch (p.State)
                        {
                            case PlanState.Open:
                                <span class="badge text-bg-success">Відкритий</span>
                                break;
                            case PlanState.Close:
                                <span class="badge text-bg-secondary">Закритий</span>
                                break;
                        }
                    </td>
                    <td>@p.Author</td>
                </RowTemplate>
            </TableBaseComponent>
        </div>
    }
    else
    {
        <div class="h5 px-2">@((Busy ? "Завантаження…" : "Плани відсутні або нічого не знайдено."))</div>
    }
</div>
