@page "/plans/{Id:guid}"
@using eRaven.Domain.Enums

@if (_loading)
{
    <p>Завантаження…</p>
}
else if (_plan is null)
{
    <div class="alert alert-warning">План не знайдено.</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="d-flex align-items-center flex-wrap gap-3">
                <div class="fs-6 fw-semibold">№ @_plan.PlanNumber</div>

                <span class="badge @( _plan.State == PlanState.Close ? "bg-success" : "bg-secondary")">
                    @_plan.State
                </span>

                <div class="vr d-none d-md-block"></div>

                <div class="small text-muted">
                    Створено (UTC): @_plan.RecordedUtc.ToString("dd.MM.yyyy HH:mm")
                </div>

                <div class="small text-muted">Автор: @_plan.Author</div>

                <!-- Правий кластер: наказ + кнопка -->
                <div class="ms-auto d-flex align-items-center gap-3 small">
                    <div>
                        Наказ:
                        @if (_plan.OrderId is Guid oid)
                        {
                            <a class="link" href="@($"/orders/{oid}")">@oid.ToString()[..8]…</a>
                        }
                        else
                        {
                            <span class="text-muted">Очікує</span>
                        }
                    </div>

                    <!-- ✅ кнопка вирівняна по вертикалі -->
                    <a class="btn btn-secondary btn-sm" href="/plans">← До списку</a>
                </div>
            </div>
        </div>
    </div>

    <PlanActionsPanel PlanId="Id"
                      ReadOnly="@(_plan.State == PlanState.Close || _plan.OrderId is not null)" />

}
