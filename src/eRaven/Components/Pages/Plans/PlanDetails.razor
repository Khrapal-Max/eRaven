@page "/plans/{Id:guid}"

<h3 class="mb-3">Деталі плану</h3>

@if (_loading)
{
    <p>Завантаження…</p>
}
else if (_plan is null)
{
    <div class="alert alert-warning">План не знайдено.</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3"><strong>Номер</strong><div>@_plan.PlanNumber</div></div>
                <div class="col-md-2"><strong>Стан</strong><div>@_plan.State</div></div>
                <div class="col-md-3"><strong>Автор</strong><div>@_plan.Author</div></div>
                <div class="col-md-4"><strong>Створено (UTC)</strong><div>@_plan.RecordedUtc:yyyy-MM-dd HH:mm</div></div>
            </div>
            <div class="row mt-2">
                <div class="col-md-12">
                    <strong>Наказ</strong>
                    <div>
                        @if (_plan.OrderId is Guid oid)
                        {
                            <a class="link" href="@($"/orders/{oid}")">@oid</a>
                        }
                        else
                        {

                            <span class="text-muted">—</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* <PlanActionsPanel PlanId="Id"
                      ReadOnly="@(_plan.State == PlanState.Close || _plan.OrderId is not null)" /> *@

    <div class="mt-3">
        <a class="btn btn-outline-secondary" href="/plans">← До списку</a>
    </div>
}
