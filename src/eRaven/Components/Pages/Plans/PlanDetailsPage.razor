@* @page "/plans/{id:guid}"

@using eRaven.Domain.Enums
@using eRaven.Domain.Models
@using eRaven.Components.Shared.ConfirmModal
@using eRaven.Components.Pages.Plans.Modals

<PageTitle>План @(_plan?.PlanNumber ?? "")</PageTitle>

<div class="container-fluid py-2 d-flex flex-column" style="gap:.75rem; min-height:70vh;">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div class="h5 mb-0">
            План: <span>@_plan?.PlanNumber</span>
            @if (_plan is not null)
            {
                <small class="ms-2">
                    створено @(_plan.RecordedUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")) · автор @_plan.Author
                </small>
            }
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" @onclick="Back" disabled="@Busy">
                <i class="bi bi-arrow-left"></i> Назад
            </button>

            <button class="btn btn-sm btn-success" @onclick="OpenAddAction" disabled="@( !CanEdit )">
                <i class="bi bi-person-plus"></i> Додати дію
            </button>

            <button class="btn btn-sm btn-primary" @onclick="OpenAddBatch" disabled="@( !CanEdit )">
                <i class="bi bi-collection"></i> Пакет дій
            </button>

            <button class="btn btn-sm btn-warning" @onclick="ClosePlan" disabled="@( !CanEdit )">
                <i class="bi bi-lock"></i> Закрити план
            </button>
        </div>
    </div>

    @if (Busy)
    {
        <div class="h5 px-2">Завантаження…</div>
    }
    else if (_plan is null)
    {
        <div class="alert alert-danger">План не знайдено.</div>
    }
    else
    {
        <div class="bg-dark rounded p-2">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-white me-2">Стан:</span>
                    @if (_plan.State == PlanState.Open)
                    {
                        <span class="badge text-bg-success">Відкритий</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">Закритий</span>
                    }
                </div>
                <div class="text-muted">Учасників: @_participants.Count · Дій: @_actions.Count</div>
            </div>
        </div>

        <div class="bg-dark rounded flex-grow-1 p-0">
            <TableBaseComponent Items="_participants" TItem="PlanParticipant" Class="table align-middle mb-0">
                <TableHeader>
                    <th class="text-black">ПІБ</th>
                    <th class="text-black">Звання</th>
                    <th class="text-black">Посада</th>
                    <th class="text-black">Підрозділ</th>
                    <th class="text-black text-center">Остання дія</th>
                    <th class="text-black text-center">Дій</th>
                    <th class="text-black text-center">Додати</th>
                </TableHeader>

                <RowTemplate Context="pp">
                    <td>@pp.FullName</td>
                    <td>@pp.RankName</td>
                    <td>@pp.PositionName</td>
                    <td>@pp.UnitName</td>
                    <td class="text-center">
                        @{
                            var last = _actions.Where(a => a.PersonId == pp.PersonId)
                            .OrderByDescending(a => a.EventAtUtc)
                            .ThenByDescending(a => a.RecordedUtc)
                            .FirstOrDefault();
                            if (last is null)
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                <span class="badge text-bg-info">
                                    @last.ActionType @last.EventAtUtc.ToLocalTime().ToString("dd.MM HH:mm")
                                </span>
                            }
                        }
                    </td>
                    <td class="text-center">@_actions.Count(a => a.PersonId == pp.PersonId)</td>
                    <td class="text-center">
                        <!-- ✅ async-лямбда, викликає перегрузку з параметром -->
                        <button class="btn btn-sm btn-success"
                                title="Додати дію для цієї особи"
                                @onclick="async () => await OpenAddAction(pp.PersonId)"
                                disabled="@Busy || _plan.State != PlanState.Open">
                            <i class="bi bi-plus-circle"></i>
                        </button>
                    </td>
                </RowTemplate>
            </TableBaseComponent>
        </div>

        <div class="bg-dark rounded p-2">
            <div class="fw-semibold mb-1 text-white">Журнал дій</div>
            <TableBaseComponent Items="_actions.OrderByDescending(a => a.EventAtUtc).ThenByDescending(a => a.RecordedUtc).ToList()"
                                TItem="PlanParticipantAction"
                                Class="table table-sm align-middle mb-0">
                <TableHeader>
                    <th class="text-black">ПІБ</th>
                    <th class="text-black text-center">Дія</th>
                    <th class="text-black text-center">Коли</th>
                    <th class="text-black">Локація</th>
                    <th class="text-black">Група</th>
                    <th class="text-black">Екіпаж</th>
                    <th class="text-black">Прим.</th>
                </TableHeader>
                <RowTemplate Context="a">
                    <td>@_participants.FirstOrDefault(p => p.PersonId == a.PersonId)?.FullName</td>
                    <td class="text-center">
                        @if (a.ActionType == PlanActionType.Dispatch)
                        {
                            <span class="badge text-bg-warning text-dark">Dispatch</span>
                        }
                        else
                        {

                            <span class="badge text-bg-secondary">Return</span>
                        }
                    </td>
                    <td class="text-center">@a.EventAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@a.Location</td>
                    <td>@a.GroupName</td>
                    <td>@a.CrewName</td>
                    <td>@a.Note</td>
                </RowTemplate>
            </TableBaseComponent>
        </div>
    }
</div>

<ConfirmModal @ref="_confirm" />

<AddActionModal @ref="_addActionModal"
                PlanNumber="@(_plan?.PlanNumber ?? string.Empty)"
                PreselectedPersonId="@_preselectedPersonId"
                OnSaved="OnActionSaved" />

@* <AddBatchModal @ref="_addBatchModal"
               OnSaved="OnBatchSaved" /> *@
 