@* -----------------------------------------------------------------------------
   PlanDetailsPage (view)
   - таблиця елементів плану
   - модал додавання елементів (2 кроки)
   ----------------------------------------------------------------------------- *@

@page "/plans/{Id:guid}"

@using eRaven.Domain.Enums
@using eRaven.Domain.Models
@using eRaven.Application.ViewModels.PlanViewModels
@using eRaven.Components.Pages.Plans.Modals

<PageTitle>План @(_plan?.PlanNumber ?? "—")</PageTitle>

<div class="container-fluid py-2" style="min-height:70vh;">
    <div class="row g-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <div class="d-flex flex-column">
                        <div class="h5 mb-0">
                            План: <span class="fw-semibold">@(_plan?.PlanNumber ?? "—")</span>
                        </div>
                        <div class="small text-secondary">
                            Стан: @(_plan?.State == PlanState.Open ? "Відкрито" : "Закрито"),
                            записано: @(_plan?.RecordedUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-secondary" @onclick="GoBack" disabled="@_busy">Назад</button>
                        <button class="btn btn-sm btn-primary"
                                title="Додати елементи"
                                @onclick="OpenModalAsync"
                                disabled="@(_busy || !Editable)">
                            <i class="bi bi-plus-circle"></i> Додати елементи
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="bg-dark rounded d-flex">
                @if (_elements.Any())
                {
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-black">ПІБ / ІПН / Посада</th>
                                <th class="text-black text-center">Статус</th>
                                <th class="text-black text-center">Дія</th>
                                <th class="text-black text-center">Дата/час</th>
                                <th class="text-black">Локація</th>
                                <th class="text-black">Група</th>
                                <th class="text-black">Екіпаж</th>
                                <th class="text-black text-center">Нотатка</th>
                                <th class="text-black text-center">Дії</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in _elements)
                            {
                                var p = e.PlanParticipantSnapshot;
                                <tr>
                                    <td>
                                        <div class="fw-semibold text-truncate" title="@p?.FullName">@p?.FullName</div>
                                        <div class="small text-secondary">@p?.Rnokpp</div>
                                        @if (!string.IsNullOrWhiteSpace(p?.PositionSnapshot))
                                        {
                                            <div class="small text-secondary">@p!.PositionSnapshot</div>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrWhiteSpace(p?.StatusKindCode))
                                        {
                                            <span class="badge text-bg-light">@p!.StatusKindCode</span>
                                        }
                                        else
                                        {

                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @(e.Type == PlanType.Dispatch ? "Відрядити" : "Повернути")
                                    </td>
                                    <td class="text-center">@e.EventAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@e.Location</td>
                                    <td>@e.GroupName</td>
                                    <td>@e.ToolType</td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrWhiteSpace(e.Note))
                                        {
                                            <span class="badge text-bg-light" title="@e.Note">нотатка</span>
                                        }
                                        else
                                        {

                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-danger"
                                                title="Видалити елемент"
                                                @onclick="() => RemoveElementAsync(_plan!.Id, e.Id)"
                                                disabled="@(!Editable || _busy)">
                                            <i class="bi bi-dash-circle"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="h5 px-2 py-3 mb-0">Елементи відсутні.</div>
                }
            </div>
        </div>
    </div>
</div>

<AddPlanElementsModal Open="@_modalOpen"
                      PlanId="@Id"
                      People="@_roster"
                      ExistingElements="@_elements"
                      AllowedDispatchFromStatusCode="@_opts?.ReturnStatusKind?.Code"
                      AllowedDispatchFromStatusName="@(_opts?.ReturnStatusKind?.Name)"
                      OnAdd="OnModalAddAsync"
                      OnClose="CloseModalAsync" />