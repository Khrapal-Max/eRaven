@using eRaven.Domain.Enums
@using eRaven.Application.ViewModels.PlanViewModels
@using eRaven.Components.Shared.TableBaseComponent
@using eRaven.Components.Pages.Plans.Modals

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Дії плану</span>
        <button class="btn btn-sm btn-primary" @onclick="OpenCreate" disabled="@ReadOnly">Додати дію</button>
    </div>

    <TableBaseComponent TItem="PlanActionViewModel"
                        Class="table-sm align-middle"
                        Items="_actions"
                        SelectedItem="_selected"
                        SelectedItemChanged="OnSelectedChanged"
                        OnClick="_ => {}"
                        MaxHeight="60vh" MinHeight="300px">
        <TableHeader>
            <th scope="col" class="text-black">Особа</th>
            <th scope="col" class="text-black">Дія</th>
            <th scope="col" class="text-black">UTC</th>
            <th scope="col" class="text-black">Локація</th>
            <th scope="col" class="text-black">Група</th>
            <th scope="col" class="text-black">Зміна</th>
            <th scope="col" class="text-black" style="width:120px"></th>
        </TableHeader>

        <RowTemplate Context="a">
            <td>@a.FullName (@a.Rnokpp)</td>
            <td>@a.ActionType</td>
            <td>@a.EventAtUtc:yyyy-MM-dd HH:mm</td>
            <td>@a.Location</td>
            <td>@a.GroupName</td>
            <td>@a.CrewName</td>
            <td class="text-end">
                <button class="btn btn-sm btn-outline-danger"
                        @onclick="(e) => DeleteAsync(a.Id)"
                        @onclick:stopPropagation="true"
                        disabled="@ReadOnly">Видалити</button>
            </td>
        </RowTemplate>
    </TableBaseComponent>

    @if (_loading)
    {
        <div class="p-3 text-muted">Завантаження…</div>
    }
    else if (_actions.Count == 0)
    {
        <div class="p-3 text-muted">Поки немає дій</div>
    }
</div>

<CreatePlanActionModal @ref="_createModal"
                       PlanId="PlanId"
                       OnCreated="HandleCreated"
                       ReadOnly="ReadOnly" />
