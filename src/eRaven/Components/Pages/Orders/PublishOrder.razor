@page "/orders/publish"

<h3 class="mb-3">Публікація добового наказу</h3>

<div class="card mb-3">
    <div class="card-body">
        <EditForm Model="_vm" OnValidSubmit="PublishAsync">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">№ наказу</label>
                    <InputText class="form-control" @bind-Value="_vm.Name" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Час чинності (UTC)</label>
                    <InputDate DateFormat="yyyy-MM-ddTHH:mm" class="form-control" @bind-Value="_effectiveDate" />
                    <div class="form-text">Дата без TZ — інтерпретується як UTC</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Автор</label>
                    <InputText class="form-control" @bind-Value="_vm.Author" />
                </div>
            </div>

            <hr />

            <div class="mb-2">
                <strong>Виберіть відкриті плани (без наказу)</strong>
            </div>

            @if (_loadingPlans)
            {
                <p>Завантаження планів…</p>
            }
            else if (_openPlans.Count == 0)
            {
                <div class="alert alert-info">Немає відкритих планів.</div>
            }
            else
            {
                <div class="list-group mb-3">
                    @foreach (var p in _openPlans)
                    {
                        <label class="list-group-item">
                            <input class="form-check-input me-1" type="checkbox" checked="@_selectedPlanIds.Contains(p.Id)"
                                   @onchange="(e) => TogglePlan(p.Id, e.Value is bool b && b)" />
                            <span class="me-2">@p.PlanNumber</span>
                            <span class="badge bg-secondary">створено @p.RecordedUtc:MM-dd HH:mm</span>
                        </label>
                    }
                </div>
            }

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="autoReturn" @bind="_vm.AutoReturnForOpenDispatch" />
                <label class="form-check-label" for="autoReturn">
                    Автоматично закривати відкриті Dispatch (додати Return з часом наказу)
                </label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@(_busy || _selectedPlanIds.Count == 0)">Опублікувати</button>
                <a class="btn btn-outline-secondary" href="/orders">Скасувати</a>
            </div>
        </EditForm>
    </div>
</div>
