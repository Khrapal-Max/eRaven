@page "/orders"
@using eRaven.Components.Shared.TableBaseComponent
@using eRaven.Application.ViewModels.OrderViewModels

<h3 class="mb-3">Накази</h3>

<div class="d-flex justify-content-between mb-3">
    <a class="btn btn-success" href="/orders/publish">Новий добовий наказ</a>
    <button class="btn btn-outline-secondary" @onclick="LoadAsync" disabled="@_busy">Оновити</button>
</div>

<div class="card">
    <div class="card-header">Усі накази</div>

    <TableBaseComponent TItem="OrderViewModel"
                        Class="align-middle"
                        Items="_orders"
                        SelectedItem="_selected"
                        SelectedItemChanged="OnSelectedChanged"
                        OnClick="OnRowClick"
                        MaxHeight="60vh"
                        MinHeight="300px">
        <TableHeader>
            <th scope="col">№</th>
            <th scope="col">Чинність (UTC)</th>
            <th scope="col">Створено</th>
            <th scope="col">Автор</th>
            <th scope="col" style="width:160px"></th>
        </TableHeader>

        <RowTemplate Context="o">
            <td>@o.Name</td>
            <td>@o.EffectiveMomentUtc:yyyy-MM-dd HH:mm</td>
            <td>@o.RecordedUtc:yyyy-MM-dd HH:mm</td>
            <td>@o.Author</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-primary me-2"
                   href="@($"/orders/{o.Id}")"
                   @onclick:stopPropagation="true">Деталі</a>

                <button class="btn btn-sm btn-outline-danger"
                        @onclick="(e) => DeleteAsync(o.Id)"
                        @onclick:stopPropagation="true"
                        disabled="@_busy">
                    Видалити
                </button>
            </td>
        </RowTemplate>
    </TableBaseComponent>

    @if (_loading)
    {
        <div class="p-3 text-muted">Завантаження…</div>
    }
    else if (_orders.Count == 0)
    {
        <div class="p-3 text-muted">Немає наказів</div>
    }
</div>
