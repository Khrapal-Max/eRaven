@page "/orders/{Id:guid}"
@using eRaven.Components.Shared.TableBaseComponent
@using eRaven.Application.ViewModels.OrderViewModels

<h3 class="mb-3">Деталі наказу</h3>

@if (_loading)
{
    <p>Завантаження…</p>
}
else if (_details is null)
{
    <div class="alert alert-warning">Наказ не знайдено.</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3"><strong>№ наказу</strong><div>@_details.Order.Name</div></div>
                <div class="col-md-3"><strong>Чинність (UTC)</strong><div>@_details.Order.EffectiveMomentUtc:yyyy-MM-dd HH:mm</div></div>
                <div class="col-md-3"><strong>Створено</strong><div>@_details.Order.RecordedUtc:yyyy-MM-dd HH:mm</div></div>
                <div class="col-md-3"><strong>Автор</strong><div>@_details.Order.Author</div></div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">Плани</div>
                <div class="list-group list-group-flush">
                    @if (_details.PlanIds.Count == 0)
                    {
                        <div class="list-group-item text-muted">—</div>
                    }
                    else
                    {
                        @foreach (var pid in _details.PlanIds)
                        {
                            <a class="list-group-item list-group-item-action" href="@($"/plans/{pid}")">@pid</a>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header">Підтверджені дії</div>

                @if (_details.Actions.Count == 0)
                {
                    <div class="p-3 text-muted">—</div>
                }
                else
                {
                    <!-- ✅ Спільний табличний компонент -->
                    <TableBaseComponent TItem="OrderActionViewModel"
                                        Class="table-sm align-middle"
                                        Items="_details.Actions.OrderBy(a => a.EventAtUtc).ToList()"
                                        SelectedItem="_selectedAction"
                                        SelectedItemChanged="OnSelectedActionChanged"
                                        OnClick="OnActionRowClick"
                                        MaxHeight="60vh"
                                        MinHeight="300px">
                        <TableHeader>
                            <th scope="col">Особа</th>
                            <th scope="col">Дія</th>
                            <th scope="col">UTC</th>
                            <th scope="col">Локація</th>
                            <th scope="col">Група</th>
                            <th scope="col">Зміна</th>
                        </TableHeader>

                        <RowTemplate Context="a">
                            <td>@a.FullName (@a.Rnokpp)</td>
                            <td>@a.ActionType</td>
                            <td>@a.EventAtUtc:yyyy-MM-dd HH:mm</td>
                            <td>@a.Location</td>
                            <td>@a.GroupName</td>
                            <td>@a.CrewName</td>
                        </RowTemplate>
                    </TableBaseComponent>
                }
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a class="btn btn-outline-secondary" href="/orders">← До списку</a>
    </div>
}
