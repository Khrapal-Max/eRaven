@page "/status-kinds"

@using eRaven.Components.Pages.StatusKids.Modals;

<section class="d-flex justify-content-between mb-2">
    <div class="fw-bold text-black">Правила переходів статусів</div>

    <button class="btn btn-sm btn-primary" @onclick="OpenCreateModal" disabled="@_busy">
        <i class="bi bi-plus"></i> Додати статус
    </button>
</section>

<div class="row g-3">
    <!-- Ліва панель -->
    <div class="col-12 col-md-5">
        <div class="card">
            <div class="card-header py-2">
                <strong>З якого статусу</strong>
            </div>

            <div class="card-body p-0">
                <div class="panel-scroll" style="max-height:70vh; overflow:auto;">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Статус</th>
                                <th style="width:96px;">Код</th>
                                <th style="width:80px;" class="text-center">Порядок</th>
                                <th style="width:90px;" class="text-center">Активний</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_kinds.Count == 0)
                            {
                                <tr><td colspan="4" class="text-secondary text-center py-3">Немає статусів</td></tr>
                            }
                            else
                            {
                                @foreach (var k in _kinds)
                                {
                                    var isSelected = k.Id == _selectedFromId;
                                    <tr class="@(isSelected ? "table-active" : null)"
                                        style="cursor:pointer"
                                        @onclick="() => SelectFromAsync(k.Id)">
                                        <td>@k.Name</td>
                                        <td><span class="badge bg-light text-dark">@k.Code</span></td>
                                        <td class="text-center">@k.Order</td>
                                        <td class="text-center">
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   checked="@k.IsActive"
                                                   disabled="@_busy"
                                                   @onclick="(async _ => await ToggleActiveAsync(k))" />
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Права панель -->
    <div class="col-12 col-md-7">
        <div class="card">
            <div class="card-header py-2 d-flex align-items-center justify-content-between">
                <div>
                    <strong>Дозволені переходи</strong>
                    <span class="text-secondary ms-2">
                        з: @_currentFromName (@_currentFromCode)
                    </span>
                </div>
                <span class="small text-secondary">Вибрано: @_allowedToIds.Count</span>
            </div>

            <div class="card-body p-0">
                @if (_selectedFromId == 0)
                {
                    <div class="p-3 text-secondary">Оберіть статус зліва.</div>
                }
                else
                {
                    <div class="panel-scroll" style="max-height:70vh; overflow:auto;">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="width:56px;" class="text-center">Дозволено</th>
                                    <th>Статус</th>
                                    <th style="width:96px;">Код</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var k in _kinds)
                                {
                                    var self = k.Id == _selectedFromId;
                                    var isChecked = _allowedToIds.Contains(k.Id);

                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   disabled="@self"
                                                   checked="@isChecked"
                                                   @onchange="(ChangeEventArgs e) => ToggleToAsync(k.Id, e.Value is bool b && b)" />
                                        </td>
                                        <td>
                                            @k.Name
                                            @if (self)
                                            {
                                                <span class="text-muted small ms-1">(сам-на-себе — заборонено)</span>
                                            }
                                        </td>
                                        <td><span class="badge bg-light text-dark">@k.Code</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>        
        </div>
    </div>
</div>


<!-- Підтвердження зміни активності / формові сценарії -->
<ConfirmModal @ref="Confirm" Title="Підтвердження" ConfirmText="Підтвердити" CancelText="Скасувати" />

<!-- Створення статуса -->
<StatusCreateModal @ref="_createModal" OnCreated="OnCreatedAsync" />
